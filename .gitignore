# ===========================================
# Trinity-specific exclusions
# ===========================================

# Test artifacts (generated during testing)
test-results/
test-screenshots/
tests/reports/*.json
tests/reports/*.md
tests/reports/*.html
!tests/reports/README.md

# Database backups (sensitive)
backups/

# Dynamic test repositories (created during testing)
repositories/
# Exception: Process engine code repositories
!src/backend/services/process_engine/repositories/

# Archive folder (local development artifacts, root only)
/archive/

# Screenshots in root (test artifacts)
*.png
# Allow PWA icons
!src/frontend/public/icons/*.png

# Frontend build output
src/frontend/dist/

# Coverage reports
tests/reports/coverage/

# Test agent templates (created during automated tests)
src/backend/config/agent-templates/test-*/

# Agent template runtime artifacts (generated during execution)
config/agent-templates/**/memory/
config/agent-templates/**/outputs/
config/agent-templates/**/metrics.json
.playwright-mcp/
.local/

# Claude Code internals
.claude/projects/
.claude/statsig/
.claude/todos/
.claude/debug/
.claude/cache/
.claude/plugins/
.claude/shell-snapshots/
.claude.json

# Runtime
.cache/
.sudo_as_admin_successful
.trinity/
content/
session-files/
